      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/eat/detail",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/go/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/go/detail",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
